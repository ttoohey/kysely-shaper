{
  "name": "kysely-shaper",
  "version": "0.0.0",
  "main": "./lib/cjs/index.js",
  "types": "./lib/cjs/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "default": "./lib/cjs/index.js",
        "types": "./lib/cjs/index.d.ts"
      },
      "import": {
        "default": "./lib/esm/index.js",
        "types": "./lib/esm/index.d.ts"
      }
    }
  },
  "type": "module",
  "files": [
    "lib/**/*.js",
    "lib/**/*.d.ts"
  ],
  "scripts": {
    "build": "rimraf lib && npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "ttoohey@users.noreply.github.com",
  "license": "ISC",
  "description": "Helper for kysely to create a composable, type-safe, SQL query builder.",
  "keywords": [
    "kysely"
  ],
  "dependencies": {
    "kysely": "^0.28.8"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "prettier": "^3.8.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "homepage": "https://github.com/ttoohey/kysely-shaper",
  "repository": {
    "type": "git",
    "url": "https://github.com/ttoohey/kysely-shaper.git"
  }
}
